generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @unique
  email     String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Faculty {
  id        String    @id @unique
  email     String    @unique
  name      String
  dept      String
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  students    Student[]
  sessions    Session[]
  attendances Attendance[]

  @@map("faculty")
}

model Student {
  id        String   @id @default(uuid())
  name      String
  gender    String
  dept      String
  cutOff    Float    @map("cut_off")
  community String
  quota     String
  status    String   // ex: active, counselled, pending
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")


facultyId String   @map("faculty_id")

faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@map("students")
}

model Session {
  id        Int       @id @default(autoincrement())
  startTime DateTime  @map("start_time")
  endTime   DateTime? @map("end_time")
  qrToken   String    @map("qr_token")
  createdAt DateTime  @default(now()) @map("created_at")

  facultyId String    @map("faculty_id")
  faculty   Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ActiveQR {
  id               Int      @id @default(autoincrement())
  attendanceToken  String   @unique @map("attendance_token")
  sessionToken     String   @unique @map("session_token")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("active_qr")
}

model Attendance {
  id          Int       @id @default(autoincrement())
  checkinTime DateTime  @map("checkin_time")
  checkoutTime DateTime? @map("checkout_time")
  createdAt   DateTime  @default(now()) @map("created_at")

  facultyId String    @map("faculty_id")
  faculty   Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@map("attendance")
}

model Department {
  code String @id @unique 
  name String             

  @@map("departments")
}
