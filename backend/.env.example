# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/ftta_db"

# Google OAuth credentials
# Get these from: https://console.cloud.google.com/
# Create a project → APIs & Services → Credentials → Create OAuth client ID
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# JWT signing secret
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Domain validation for faculty login (the part after @)
# Only emails from this domain will be accepted as faculty
FACULTY_DOMAIN="college.edu"

# The specific Google email that becomes Admin
ADMIN_EMAIL="admin@yourdomain.com"

# Your React dev server URL
FRONTEND_URL="http://localhost:5173"

# Express server port
PORT=3000

# How long (minutes) before an unscanned QR code expires automatically
QR_EXPIRY_MINUTES=5
